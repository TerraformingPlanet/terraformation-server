# =============================================================================
# Terraformation — Backend & Tooling repo .gitignore
# =============================================================================
# Ce repo versionne : SimulationCore/, DedicatedServer/, Mcp/,
#                    Documentation/, Tools/, Artifacts/, docker-compose.yml
# Le client Unity (Game/) a son propre repo : Wafhi3n/Game-unity-terra

# =============================================================================
# Unity (Game/) — repo séparé, exclu ici
# =============================================================================
Game/

# =============================================================================
# Python (SimulationCore/, DedicatedServer/, Mcp/)
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
*.dylib

# Environments
.venv/
venv/
env/
.env

# =============================================================================
# Docker
# =============================================================================
*.env.local
.docker/

# =============================================================================
# Artifacts (captures smoke tests — conserver la structure, ignorer le contenu)
# =============================================================================
Artifacts/SmokeTests/*/
!Artifacts/SmokeTests/.gitkeep

# =============================================================================
# Logs
# =============================================================================
Logs/
*.log

# =============================================================================
# Documentation upstream (docs de librairies tierces — ne pas versionner)
# =============================================================================
Documentation/Hierarchie_h3/
Documentation/mcp/quickstart.md
Documentation/mcp/openapi.md
Documentation/mcp/custom.md
Documentation/mcp/proxy.md

# =============================================================================
# Editeurs / OS
# =============================================================================
.vs/
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
