# Roadmap Service — local configuration
# Copy to .env and adjust as needed, then: python run.py

# Path to the SQLite database file (auto-defaults to roadmap.db next to run.py)
# DB_PATH=E:/terraformation/Roadmap/roadmap.db

# Absolute path to the workspace root (used to resolve assertion_script paths)
# WORKSPACE_PATH=E:/terraformation

# Port for the FastAPI server
# PORT=8001
