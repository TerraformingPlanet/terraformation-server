# ── Terraformation — environment template ─────────────────────────────────────
# Copy this file to .env and fill in the real values.
# .env is git-ignored; never commit secrets.

# PostgreSQL
POSTGRES_PASSWORD=terralocal

# Simulation server mode  (postgres | memory)
SERVER_MODE=postgres

# ── Agent LLM (Phase 8.5) ─────────────────────────────────────────────────────
# Base URL of the OpenAI-compatible API (no trailing slash, no path suffix)
LLM_BASE_URL=https://ai.prv.jerem.ovh/openai

# Model identifier as returned by /v1/models
LLM_MODEL=Qwen3.6-35B-A3B-MXFP4_MOE

# API key — generate from OpenWebUI Settings → API Keys
LLM_API_KEY=sk-...

# Call mode: "json" (response_format) or "tools" (function-calling)
LLM_MODE=tools

# How often the agent fires (every N simulation ticks)
AGENT_TICK_INTERVAL=10
